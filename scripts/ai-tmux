#!/bin/bash
# ai-tmux — Auto-wrap AI CLI tools in tmux sessions
#
# Behavior:
#   - If already inside tmux → run command directly
#   - If NOT in tmux → create a named tmux session and run command inside it
#
# Session naming: <command>-<basename-of-cwd>-<N> (e.g. claude-agent-home-1)
#
# Install: add to ~/.config/fish/config.fish (or .bashrc/.zshrc):
#
#   # Fish:
#   function claude; ~/Git/agent-home/scripts/ai-tmux claude $argv; end
#   function codex; ~/Git/agent-home/scripts/ai-tmux codex $argv; end
#
#   # Bash/Zsh:
#   claude() { ~/Git/agent-home/scripts/ai-tmux claude "$@"; }
#   codex() { ~/Git/agent-home/scripts/ai-tmux codex "$@"; }

set -e

# First argument is the command name when called as: ai-tmux <cmd> [args...]
CMD_NAME="${1:?Usage: ai-tmux <command> [args...]}"
shift

# Resolve real binary from PATH
REAL_CMD=$(command -v "$CMD_NAME" 2>/dev/null)
if [ -z "$REAL_CMD" ]; then
  echo "Error: '$CMD_NAME' not found in PATH" >&2
  exit 1
fi

# If already inside tmux, just run directly
if [ -n "$TMUX" ]; then
  exec "$REAL_CMD" "$@"
fi

# Generate tmux session name: <command>-<dirname>-<N>
DIR_BASE=$(basename "$PWD")
BASE_NAME=$(printf '%s-%s' "$CMD_NAME" "$DIR_BASE" | tr -c 'a-zA-Z0-9_-' '-' | head -c 60)

# Find next available number
i=1
while tmux has-session -t "${BASE_NAME}-${i}" 2>/dev/null; do
  i=$((i + 1))
done
SESSION_NAME="${BASE_NAME}-${i}"

# Create tmux session and run the command
exec tmux new-session -s "$SESSION_NAME" -c "$PWD" "$REAL_CMD" "$@"

#!/bin/bash
# ai-tmux — Auto-wrap AI CLI tools in tmux sessions
#
# Usage: ai-tmux <command> [args...]
#   e.g.: ai-tmux claude
#         ai-tmux claude --resume session-id
#         ai-tmux codex
#
# Behavior:
#   - If already inside tmux → run command directly (session name auto-detected by hook)
#   - If NOT in tmux → create a named tmux session and run command inside it
#
# Session naming: <command>-<basename-of-cwd> (e.g. claude-agent-home)
#
# Install:
#   1. Move real binary/symlink out of the way:
#      mv ~/.local/bin/claude ~/.local/bin/claude-real
#   2. Symlink wrapper in its place:
#      ln -sf ~/Git/agent-home/scripts/ai-tmux ~/.local/bin/claude
#
# Or use directly: ai-tmux claude-real [args...]

set -e

SCRIPT_NAME=$(basename "$0")

# Map script name to the real binary path
# After installation, originals are renamed to <name>-real
case "$SCRIPT_NAME" in
  claude)  REAL_CMD="$HOME/.local/bin/claude-real" ;;
  codex)   REAL_CMD="$HOME/.local/bin/codex-real" ;;
  crush)   REAL_CMD="$HOME/.local/bin/crush-real" ;;
  ai-tmux) REAL_CMD="$1"; shift ;;
  *)       REAL_CMD="${SCRIPT_NAME}-real" ;;
esac

if [ ! -x "$REAL_CMD" ]; then
  echo "Error: real binary not found at '$REAL_CMD'" >&2
  echo "Did you rename the original? e.g.: mv ~/.local/bin/claude ~/.local/bin/claude-real" >&2
  exit 1
fi

# If already inside tmux, just run directly
if [ -n "$TMUX" ]; then
  exec "$REAL_CMD" "$@"
fi

# Generate tmux session name: <command>-<dirname>
CMD_BASE="$SCRIPT_NAME"
DIR_BASE=$(basename "$PWD")
BASE_NAME="${CMD_BASE}-${DIR_BASE}"

# Sanitize: only allow [a-zA-Z0-9_-]
BASE_NAME=$(echo "$BASE_NAME" | tr -c 'a-zA-Z0-9_-' '-' | head -c 60)

# If session already exists, append counter
SESSION_NAME="$BASE_NAME"
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  i=2
  while tmux has-session -t "${BASE_NAME}-${i}" 2>/dev/null; do
    i=$((i + 1))
  done
  SESSION_NAME="${BASE_NAME}-${i}"
fi

# Create tmux session and run the command
exec tmux new-session -s "$SESSION_NAME" -c "$PWD" "$REAL_CMD" "$@"

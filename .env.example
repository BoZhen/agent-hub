# Monitor agent — LLM provider settings.
# Copy to .env and fill in. .env is gitignored.

MONITOR_LLM_BASE_URL=https://api.deepseek.com
MONITOR_LLM_API_KEY=sk-...
MONITOR_LLM_MODEL=deepseek-v4-pro

# Optional: alternative provider profiles (comma-separated names).
# Each profile reads MONITOR_LLM_<NAME>_BASE_URL / _API_KEY / _MODEL.
# MONITOR_LLM_PROFILES=deepseek,qwen-local
# MONITOR_LLM_QWEN_LOCAL_BASE_URL=http://localhost:8000/v1
# MONITOR_LLM_QWEN_LOCAL_API_KEY=not-needed
# MONITOR_LLM_QWEN_LOCAL_MODEL=qwen3.6-27b
